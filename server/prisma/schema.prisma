// SchoolOS Prisma schema.
// Multi-tenant School ERP. This is a starting slice (auth + tenancy);
// feature modules add their models incrementally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  RECEPTIONIST
  HR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  ALUMNI
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
  OTHER
}

enum ExamStatus {
  DRAFT
  PUBLISHED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum LibraryIssueStatus {
  ISSUED
  RETURNED
}

enum AnnouncementAudience {
  ALL
  TEACHERS
  STUDENTS
  PARENTS
  STAFF
}

enum HostelType {
  BOYS
  GIRLS
  MIXED
}

enum StockTxnType {
  IN
  OUT
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum LeaveType {
  CASUAL
  SICK
  ANNUAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayslipStatus {
  DRAFT
  PAID
}

enum EventType {
  GENERAL
  HOLIDAY
  EXAM
  PTM
  COMPETITION
  SPORTS
}

enum CertificateType {
  BONAFIDE
  CHARACTER
  TRANSFER
  LEAVING
}

/// A tenant. Every domain record is scoped to a school.
model School {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  email   String?
  phone   String?
  logoUrl String?

  // Profile / address.
  websiteUrl String?
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?

  // Localization & branding.
  timezone   String @default("UTC")
  currency   String @default("USD")
  locale     String @default("en")
  themeColor String @default("#2563eb")

  // Operating hours (minutes from midnight, 0–1439), e.g. 480 = 08:00.
  dayStartMinute Int @default(480)
  dayEndMinute   Int @default(900)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  academicYears        AcademicYear[]
  classes              Class[]
  subjects             Subject[]
  students             Student[]
  teachers             Teacher[]
  attendanceRecords    AttendanceRecord[]
  feeCategories        FeeCategory[]
  invoices             Invoice[]
  payments             Payment[]
  exams                Exam[]
  homeworks            Homework[]
  auditLogs            AuditLog[]
  parents              Parent[]
  assignments          Assignment[]
  timetableSlots       TimetableSlot[]
  bookCategories       BookCategory[]
  books                Book[]
  bookIssues           BookIssue[]
  vehicles             Vehicle[]
  transportRoutes      TransportRoute[]
  transportAllocations TransportAllocation[]
  announcements        Announcement[]
  hostels              Hostel[]
  hostelAllocations    HostelAllocation[]
  suppliers            Supplier[]
  inventoryItems       InventoryItem[]
  stockTransactions    StockTransaction[]
  employees            Employee[]
  leaveRequests        LeaveRequest[]
  payslips             Payslip[]
  events               Event[]
  certificates         Certificate[]
  apiKeys              ApiKey[]

  @@map("schools")
}

/// An academic session for a school (e.g. "2025-2026"). Exactly one may be current.
model AcademicYear {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  exams Exam[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("academic_years")
}

/// A grade/class within a school (e.g. "Grade 1"). Holds sections and offered subjects.
model Class {
  id        String   @id @default(uuid())
  name      String
  /// Optional numeric ordering for sorting/promotion logic (e.g. 1, 2, 10).
  level     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sections      Section[]
  classSubjects ClassSubject[]
  students      Student[]
  exams         Exam[]
  homeworks     Homework[]
  assignments   Assignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

/// A subdivision of a class (e.g. "A", "B"). Scoped to its class (and thus tenant).
model Section {
  id        String   @id @default(uuid())
  name      String
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  // Optional class teacher (homeroom). Nulled if the teacher is removed.
  classTeacherId String?
  classTeacher   Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)

  students          Student[]
  attendanceRecords AttendanceRecord[]
  homeworks         Homework[]
  assignments       Assignment[]
  timetableSlots    TimetableSlot[]

  @@unique([classId, name])
  @@index([classId])
  @@index([classTeacherId])
  @@map("sections")
}

/// A subject offered by a school (catalog), e.g. "Mathematics" / "MATH".
model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classSubjects  ClassSubject[]
  examSubjects   ExamSubject[]
  homeworks      Homework[]
  assignments    Assignment[]
  timetableSlots TimetableSlot[]

  @@unique([schoolId, code])
  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

/// Join table: which subjects a class offers.
model ClassSubject {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // Optional subject teacher for this class. Nulled if the teacher is removed.
  teacherId String?
  teacher   Teacher? @relation("SubjectTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
  @@map("class_subjects")
}

/// An enrolled student (admission record + current placement). Tenant-scoped.
model Student {
  id            String        @id @default(uuid())
  admissionNo   String
  firstName     String
  lastName      String
  gender        Gender?
  dateOfBirth   DateTime?
  email         String?
  phone         String?
  address       String?
  status        StudentStatus @default(ACTIVE)
  admissionDate DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Current placement; nulled (not deleted) if the class/section is removed.
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  guardians             Guardian[]
  attendanceRecords     AttendanceRecord[]
  invoices              Invoice[]
  marks                 Mark[]
  homeworkSubmissions   HomeworkSubmission[]
  parentLinks           ParentStudent[]
  assignmentSubmissions AssignmentSubmission[]
  bookIssues            BookIssue[]
  transportAllocation   TransportAllocation?
  hostelAllocation      HostelAllocation?
  certificates          Certificate[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@map("students")
}

/// A parent/guardian linked to a student.
model Guardian {
  id         String   @id @default(uuid())
  relation   String
  firstName  String
  lastName   String
  phone      String?
  email      String?
  occupation String?
  address    String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("guardians")
}

/// A parent's portal account, linked 1:1 to a PARENT login and to children.
model Parent {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String
  phone      String?
  occupation String?
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Login account (role PARENT). Deleting the user removes the parent record.
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  children ParentStudent[]

  @@index([schoolId])
  @@map("parents")
}

/// Link between a parent and one of their children.
model ParentStudent {
  id        String   @id @default(uuid())
  relation  String?
  createdAt DateTime @default(now())

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
  @@map("parent_students")
}

/// One attendance entry per student per day. Tenant-scoped.
model AttendanceRecord {
  id        String           @id @default(uuid())
  date      DateTime         @db.Date
  status    AttendanceStatus
  remark    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // The user who took attendance; kept (nulled) if that user is removed.
  recordedById String?
  recordedBy   User?   @relation("AttendanceRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([sectionId, date])
  @@map("attendance_records")
}

/// A fee category/label (e.g. Tuition, Transport). Tenant-scoped.
model FeeCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  invoiceItems InvoiceItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("fee_categories")
}

/// A bill issued to a student. Amounts are whole units of the school's currency.
model Invoice {
  id        String        @id @default(uuid())
  invoiceNo String
  title     String
  dueDate   DateTime?
  status    InvoiceStatus @default(PENDING)
  notes     String?
  /// Denormalized sum of line items (amount × quantity); items are fixed at creation.
  total     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  items    InvoiceItem[]
  payments Payment[]

  @@unique([schoolId, invoiceNo])
  @@index([schoolId])
  @@index([studentId])
  @@map("invoices")
}

/// A line item on an invoice. Amount may be negative for discounts/scholarships.
model InvoiceItem {
  id          String   @id @default(uuid())
  description String
  amount      Int
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  categoryId String?
  category   FeeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_items")
}

/// A payment recorded against an invoice.
model Payment {
  id        String        @id @default(uuid())
  amount    Int
  method    PaymentMethod @default(CASH)
  reference String?
  note      String?
  paidAt    DateTime      @default(now())
  createdAt DateTime      @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  recordedById String?
  recordedBy   User?   @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([schoolId])
  @@map("payments")
}

/// An examination for a class (e.g. "Mid-Term"). Holds per-subject schedule + scheme.
model Exam {
  id        String     @id @default(uuid())
  name      String
  status    ExamStatus @default(DRAFT)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)

  examSubjects ExamSubject[]

  @@index([schoolId])
  @@index([classId])
  @@map("exams")
}

/// A subject within an exam: marking scheme (max/pass) and schedule date.
model ExamSubject {
  id        String    @id @default(uuid())
  maxMarks  Int       @default(100)
  passMarks Int       @default(40)
  examDate  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  marks Mark[]

  @@unique([examId, subjectId])
  @@index([examId])
  @@map("exam_subjects")
}

/// A student's mark for one exam subject.
model Mark {
  id            String   @id @default(uuid())
  marksObtained Int?
  isAbsent      Boolean  @default(false)
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  examSubjectId String
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, studentId])
  @@index([examSubjectId])
  @@index([studentId])
  @@map("marks")
}

/// Homework assigned to a section (optionally for a subject). Tenant-scoped.
model Homework {
  id            String   @id @default(uuid())
  title         String
  description   String?
  attachmentUrl String?
  dueDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  // The teacher who set it; nulled if the teacher is removed.
  teacherId String?
  teacher   Teacher? @relation("HomeworkTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  submissions HomeworkSubmission[]

  @@index([schoolId])
  @@index([sectionId])
  @@map("homeworks")
}

/// A student's submission to a homework, with optional teacher feedback/marks.
model HomeworkSubmission {
  id            String    @id @default(uuid())
  content       String?
  attachmentUrl String?
  submittedAt   DateTime  @default(now())
  isLate        Boolean   @default(false)
  feedback      String?
  marks         Int?
  gradedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  homeworkId String
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
  @@index([studentId])
  @@map("homework_submissions")
}

/// A graded assignment for a section, with max marks and rubric criteria.
model Assignment {
  id            String   @id @default(uuid())
  title         String
  description   String?
  instructions  String?
  attachmentUrl String?
  maxMarks      Int      @default(100)
  dueDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  teacherId String?
  teacher   Teacher? @relation("AssignmentTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  criteria    AssignmentCriterion[]
  submissions AssignmentSubmission[]

  @@index([schoolId])
  @@index([sectionId])
  @@map("assignments")
}

/// A rubric criterion for an assignment (label + max points).
model AssignmentCriterion {
  id        String   @id @default(uuid())
  label     String
  maxPoints Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("assignment_criteria")
}

/// A student's submission to an assignment, with optional marks + feedback.
model AssignmentSubmission {
  id            String    @id @default(uuid())
  content       String?
  attachmentUrl String?
  submittedAt   DateTime  @default(now())
  isLate        Boolean   @default(false)
  marks         Int?
  feedback      String?
  gradedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

/// A weekly recurring timetable slot for a section. Times are minutes from midnight.
model TimetableSlot {
  id          String    @id @default(uuid())
  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int
  room        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  teacherId String?
  teacher   Teacher? @relation("TimetableTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([sectionId, dayOfWeek])
  @@index([teacherId, dayOfWeek])
  @@map("timetable_slots")
}

/// A library book category/shelf grouping. Tenant-scoped.
model BookCategory {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  books Book[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("book_categories")
}

/// A library book (catalog record) with copy accounting. Tenant-scoped.
model Book {
  id              String   @id @default(uuid())
  title           String
  author          String?
  publisher       String?
  isbn            String?
  shelf           String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  categoryId String?
  category   BookCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  issues BookIssue[]

  @@index([schoolId])
  @@map("books")
}

/// An issue/return record for a book lent to a student.
model BookIssue {
  id         String             @id @default(uuid())
  issueDate  DateTime           @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fineAmount Int                @default(0)
  status     LibraryIssueStatus @default(ISSUED)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([bookId])
  @@index([studentId])
  @@map("book_issues")
}

/// A transport vehicle with its driver details. Tenant-scoped.
model Vehicle {
  id             String   @id @default(uuid())
  registrationNo String
  model          String?
  capacity       Int      @default(0)
  driverName     String?
  driverPhone    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  routes TransportRoute[]

  @@unique([schoolId, registrationNo])
  @@index([schoolId])
  @@map("vehicles")
}

/// A transport route (with an optional assigned vehicle and monthly fee).
model TransportRoute {
  id          String   @id @default(uuid())
  name        String
  description String?
  /// Monthly transport fee in whole currency units.
  fee         Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  stops       RouteStop[]
  allocations TransportAllocation[]

  @@index([schoolId])
  @@map("transport_routes")
}

/// A pickup/drop stop on a route.
model RouteStop {
  id           String   @id @default(uuid())
  name         String
  sequence     Int      @default(0)
  /// Pickup time as minutes from midnight.
  pickupMinute Int?
  createdAt    DateTime @default(now())

  routeId String
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  allocations TransportAllocation[]

  @@index([routeId])
  @@map("route_stops")
}

/// A student's assignment to a route + stop. One active allocation per student.
model TransportAllocation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  routeId String
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  stopId String?
  stop   RouteStop? @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([routeId])
  @@map("transport_allocations")
}

/// A notice-board announcement targeted at a role audience. Tenant-scoped.
model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  audience    AnnouncementAudience @default(ALL)
  pinned      Boolean              @default(false)
  publishedAt DateTime             @default(now())
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([schoolId, publishedAt])
  @@map("announcements")
}

/// A hostel building. Tenant-scoped.
model Hostel {
  id          String     @id @default(uuid())
  name        String
  type        HostelType @default(MIXED)
  wardenName  String?
  wardenPhone String?
  /// Monthly hostel fee in whole currency units.
  monthlyFee  Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  rooms HostelRoom[]

  @@index([schoolId])
  @@map("hostels")
}

/// A room in a hostel, with a bed capacity.
model HostelRoom {
  id         String   @id @default(uuid())
  roomNumber String
  floor      String?
  capacity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hostelId String
  hostel   Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  allocations HostelAllocation[]

  @@unique([hostelId, roomNumber])
  @@index([hostelId])
  @@map("hostel_rooms")
}

/// A student's hostel bed allocation. One active allocation per student.
model HostelAllocation {
  id        String   @id @default(uuid())
  bedLabel  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  roomId String
  room   HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([roomId])
  @@map("hostel_allocations")
}

/// A supplier/vendor. Tenant-scoped.
model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  items        InventoryItem[]
  transactions StockTransaction[]

  @@index([schoolId])
  @@map("suppliers")
}

/// An inventory item (asset or consumable) with current stock quantity.
model InventoryItem {
  id           String   @id @default(uuid())
  name         String
  category     String?
  unit         String?
  quantity     Int      @default(0)
  reorderLevel Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  transactions StockTransaction[]

  @@index([schoolId])
  @@map("inventory_items")
}

/// A stock movement (IN = purchase/restock, OUT = issue/consume).
model StockTransaction {
  id        String       @id @default(uuid())
  type      StockTxnType
  quantity  Int
  unitCost  Int?
  note      String?
  createdAt DateTime     @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([schoolId])
  @@map("stock_transactions")
}

/// A general staff/employee HR record. Tenant-scoped.
model Employee {
  id             String         @id @default(uuid())
  employeeCode   String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  designation    String?
  department     String?
  employmentType EmploymentType @default(FULL_TIME)
  joiningDate    DateTime       @default(now())
  salary         Int?
  status         StaffStatus    @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  leaveRequests LeaveRequest[]
  payslips      Payslip[]

  @@unique([schoolId, employeeCode])
  @@index([schoolId])
  @@map("employees")
}

/// A leave request from an employee, reviewed by HR.
model LeaveRequest {
  id         String      @id @default(uuid())
  type       LeaveType   @default(CASUAL)
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([employeeId])
  @@map("leave_requests")
}

/// A monthly payslip for an employee. Amounts are whole currency units.
model Payslip {
  id          String        @id @default(uuid())
  periodMonth Int
  periodYear  Int
  basicSalary Int
  allowances  Int           @default(0)
  bonus       Int           @default(0)
  deductions  Int           @default(0)
  tax         Int           @default(0)
  /// Denormalized: basic + allowances + bonus - deductions - tax.
  netPay      Int
  status      PayslipStatus @default(DRAFT)
  paidAt      DateTime?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, periodYear, periodMonth])
  @@index([schoolId, periodYear, periodMonth])
  @@map("payslips")
}

/// A school calendar event (holiday, PTM, competition, …). Tenant-scoped.
model Event {
  id          String               @id @default(uuid())
  title       String
  description String?
  type        EventType            @default(GENERAL)
  audience    AnnouncementAudience @default(ALL)
  location    String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, startDate])
  @@map("events")
}

/// An issued certificate for a student, with a public verification code.
model Certificate {
  id               String          @id @default(uuid())
  type             CertificateType
  serialNo         String
  verificationCode String          @unique
  title            String
  body             String
  issueDate        DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, serialNo])
  @@index([schoolId])
  @@index([studentId])
  @@map("certificates")
}

/// A hashed API key for third-party integrations. The raw key is shown once.
model ApiKey {
  id         String    @id @default(uuid())
  name       String
  prefix     String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("api_keys")
}

/// A teacher's HR/profile record, linked one-to-one to a login User. Tenant-scoped.
model Teacher {
  id              String      @id @default(uuid())
  employeeNo      String
  firstName       String
  lastName        String
  email           String
  phone           String?
  gender          Gender?
  dateOfBirth     DateTime?
  qualification   String?
  experienceYears Int?
  /// Monthly salary in major currency units (school's currency).
  salary          Int?
  joiningDate     DateTime    @default(now())
  status          StaffStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Login account (role TEACHER). One-to-one.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  classSections      Section[]       @relation("ClassTeacher")
  subjectAssignments ClassSubject[]  @relation("SubjectTeacher")
  homeworks          Homework[]      @relation("HomeworkTeacher")
  assignments        Assignment[]    @relation("AssignmentTeacher")
  timetableSlots     TimetableSlot[] @relation("TimetableTeacher")

  @@unique([schoolId, employeeNo])
  @@index([schoolId])
  @@map("teachers")
}

model User {
  id           String    @id @default(uuid())
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(STUDENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Tenancy: SUPER_ADMIN has no school; everyone else belongs to one.
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  refreshTokens       RefreshToken[]
  teacher             Teacher?
  parent              Parent?
  attendanceRecords   AttendanceRecord[]   @relation("AttendanceRecorder")
  paymentsRecorded    Payment[]            @relation("PaymentRecorder")
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  announcements       Announcement[]       @relation("AnnouncementAuthor")

  // Email is unique within a tenant.
  @@unique([schoolId, email])
  @@index([schoolId])
  @@map("users")
}

/// Hashed refresh tokens for rotation/revocation. One row per session.
model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

/// Single-use, hashed password-reset tokens.
model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Immutable audit trail of security-relevant actions.
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  // Actor + tenant; nulled/cascaded appropriately.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}
