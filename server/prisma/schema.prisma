// SchoolOS Prisma schema.
// Multi-tenant School ERP. This is a starting slice (auth + tenancy);
// feature modules add their models incrementally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  RECEPTIONIST
  HR
}

/// A tenant. Every domain record is scoped to a school.
model School {
  id      String  @id @default(uuid())
  name    String
  slug    String  @unique
  email   String?
  phone   String?
  logoUrl String?

  // Profile / address.
  websiteUrl String?
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?

  // Localization & branding.
  timezone   String @default("UTC")
  currency   String @default("USD")
  locale     String @default("en")
  themeColor String @default("#2563eb")

  // Operating hours (minutes from midnight, 0–1439), e.g. 480 = 08:00.
  dayStartMinute Int @default(480)
  dayEndMinute   Int @default(900)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  academicYears AcademicYear[]
  classes       Class[]
  subjects      Subject[]

  @@map("schools")
}

/// An academic session for a school (e.g. "2025-2026"). Exactly one may be current.
model AcademicYear {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("academic_years")
}

/// A grade/class within a school (e.g. "Grade 1"). Holds sections and offered subjects.
model Class {
  id        String   @id @default(uuid())
  name      String
  /// Optional numeric ordering for sorting/promotion logic (e.g. 1, 2, 10).
  level     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  sections      Section[]
  classSubjects ClassSubject[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

/// A subdivision of a class (e.g. "A", "B"). Scoped to its class (and thus tenant).
model Section {
  id        String   @id @default(uuid())
  name      String
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, name])
  @@index([classId])
  @@map("sections")
}

/// A subject offered by a school (catalog), e.g. "Mathematics" / "MATH".
model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classSubjects ClassSubject[]

  @@unique([schoolId, code])
  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("subjects")
}

/// Join table: which subjects a class offers.
model ClassSubject {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
  @@map("class_subjects")
}

model User {
  id           String    @id @default(uuid())
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(STUDENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Tenancy: SUPER_ADMIN has no school; everyone else belongs to one.
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]

  // Email is unique within a tenant.
  @@unique([schoolId, email])
  @@index([schoolId])
  @@map("users")
}

/// Hashed refresh tokens for rotation/revocation.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
