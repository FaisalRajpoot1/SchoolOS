# ---------- App ----------
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:5173

# ---------- Database (PostgreSQL) ----------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schoolos?schema=public"

# ---------- Auth ----------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- AI (Module 25, optional) ----------
# Leave ANTHROPIC_API_KEY unset to run AI features on the built-in rules engine.
# ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-8
